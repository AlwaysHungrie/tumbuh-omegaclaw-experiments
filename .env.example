# Copy to .env and fill. .env is gitignored. Do NOT paste these in chat.

# MiniMax via ASI Cloud (provider ASICloud -> ASI_API_KEY, model minimax/minimax-m2.5)
ASI_API_KEY=

# Telegram bot token from @BotFather
TG_BOT_TOKEN=

# Auth secret for the agent channel (used as `auth <secret>` first message in Telegram).
# Generate strong one: openssl rand -base64 24
OMEGACLAW_AUTH_SECRET=

# Optional
TG_POLL_TIMEOUT=20
IMAGE=singularitynet/omegaclaw:latest
